            return Ok(new
            {
                status = false,
                message = "Transaction not found"
            });
        }

        return Ok(new
        {
            status = true,
            message = "Success",
            data = data
        });
    }
    catch (Exception ex)
    {
        return Ok(new
        {
            status = false,
            message = ex.Message
        });
    }
}

