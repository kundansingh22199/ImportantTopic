public string GenerateHash(string input)
{
    using var sha512 = SHA512.Create();
    var bytes = sha512.ComputeHash(Encoding.UTF8.GetBytes(input));

    StringBuilder sb = new();
    foreach (var b in bytes)
        sb.Append(b.ToString("x2"));

    return sb.ToString();
}

public async Task<string> GeneratePaymentUrl(string orderId,string regno,string paymentType,decimal totalAmount,decimal advanceAmount,decimal paidAmount,string txnid)
{
    string key = _config["Payment:Key"];
    string salt = _config["Payment:Salt"];
    string baseUrl = _config["Payment:BaseUrl"];

    string initiateUrl = "https://testpay.easebuzz.in/payment/initiateLink";
    string payUrl = "https://testpay.easebuzz.in/pay/";

    //decimal paidAmount = paymentType == "advance" ? advanceAmount : totalAmount;
    string amt = paidAmount.ToString("0.00");

    var dt = await GetUserData(regno);

    string name = dt.Rows.Count > 0 ? dt.Rows[0]["name"]?.ToString() : "Test User";
    string email = dt.Rows.Count > 0 ? dt.Rows[0]["email"]?.ToString() : "test@gmail.com";
    string phone = dt.Rows.Count > 0 ? dt.Rows[0]["phone"]?.ToString() : "9999999999";

    string productinfo = "Booking";

    string surl = $"{baseUrl}/api/payment/success";
    string furl = $"{baseUrl}/api/payment/failure";

    // ✅ UDF VALUES
    string udf1 = orderId;
    string udf2 = regno;
    string udf3 = paymentType;
    string udf4 = "Online";
    string udf5 = amt;

    // 🔥 CORRECT HASH
    string hashString = $"{key}|{txnid}|{amt}|{productinfo}|{name}|{email}|{udf1}|{udf2}|{udf3}|{udf4}|{udf5}||||||{salt}";

    string hash = GenerateHash(hashString);

    var payload = new Dictionary<string, string>
    {
        { "key", key },
        { "txnid", txnid },
        { "amount", amt },
        { "productinfo", productinfo },
        { "firstname", name },
        { "email", email },
        { "phone", phone },
        { "surl", surl },
        { "furl", furl },
        { "hash", hash },

        { "udf1", udf1 },
        { "udf2", udf2 },
        { "udf3", udf3 },
        { "udf4", udf4 },
        { "udf5", udf5 }
    };

    using var client = new HttpClient();

    var response = await client.PostAsync(initiateUrl, new FormUrlEncodedContent(payload));
    var json = await response.Content.ReadAsStringAsync();

    if (!json.TrimStart().StartsWith("{"))
        throw new Exception("Easebuzz returned HTML → check key/salt");

    dynamic result = JsonConvert.DeserializeObject(json);

    if (result.status != 1)
        throw new Exception(result.msg.ToString());

    string accessKey = result.data;

    // ✅ SAVE TRANSACTION
    await InsertEasyBuzzTransaction(new EasyBuzzTransaction
    {
        RegNo = regno,
        OrderId = orderId,
        PaymentType = paymentType,
        PaymentMode = "Online",
        TotalAmount = totalAmount.ToString("0.00"),
        AdvanceAmount = advanceAmount.ToString("0.00"),
        PaidAmount = paidAmount,
        TxnId = txnid,
        ProductInfo = productinfo,
        Name = name,
        Email = email,
        Phone = phone,
        Surl = surl,
        Furl = furl,
        Hash = hash
    });

    return payUrl + accessKey;
}
public async Task<JObject> CheckPaymentStatusFromEasebuzz(string txnid)
{
    string key = _config["Payment:Key"];
    string salt = _config["Payment:Salt"];

    // 🔥 SIMPLE HASH (v2.1)
    string hashString = $"{key}|{txnid}|{salt}";
    string hash = GenerateHash(hashString);

    Console.WriteLine("HASH STRING:");
    Console.WriteLine(hashString);

    using var client = new HttpClient();

    var request = new HttpRequestMessage
    {
        Method = HttpMethod.Post,
        RequestUri = new Uri("https://testdashboard.easebuzz.in/transaction/v2.1/retrieve"),
        Headers =
{
    { "Accept", "application/json" }
},
        Content = new FormUrlEncodedContent(new Dictionary<string, string>
{
    { "key", key },
    { "txnid", txnid },
    { "hash", hash }
})
    };

    var response = await client.SendAsync(request);
    var body = await response.Content.ReadAsStringAsync();

    Console.WriteLine("Easebuzz V2.1 Response:");
    Console.WriteLine(body);

    if (!response.IsSuccessStatusCode)
        throw new Exception("Easebuzz API Error: " + body);

    if (string.IsNullOrWhiteSpace(body) || !body.TrimStart().StartsWith("{"))
        throw new Exception("Invalid response from Easebuzz");

    return JObject.Parse(body);
}

