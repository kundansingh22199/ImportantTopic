[HttpPost("payment/initiate")]
public async Task<IActionResult> Initiate([FromBody] PaymentRequest model)
{
    try
    {
        string token = Request.Headers["X-Auth-Token"].FirstOrDefault();
        string regno = TokenManager.ValidateToken(token);

        if (string.IsNullOrEmpty(regno))
        {
            return Unauthorized(new CommonResponse
            {
                Status = "UnAuthrized",
                Message = "Customer unauthorized!"
            });
        }
        else
        {
            string txnid = "TXN" + DateTime.Now.Ticks;
            string paymentUrl = await _contract.GeneratePaymentUrl(
                model.OrderId,
                regno,
                model.PaymentType,
                model.TotalAmount,
                model.PaidAmount,
                model.PaidAmount,
                txnid
            );

            return Ok(new
            {
                status = true,
                message = "Payment Initiated",
                data = new
                {
                    txnid,
                    paymentUrl
                }
            });
        }
    }
    catch (Exception ex)
    {
        return Ok(new
        {
            status = false,
            message = ex.Message
        });
    }
}
